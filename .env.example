# HomeDrive 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# 注意：使用单下划线 (_) 表示配置层级，例如 HOMEDRIVE_SERVER_PORT 表示 server.port

# ========== 服务配置 ==========
HOMEDRIVE_SERVER_PORT=2300
HOMEDRIVE_SERVER_HOST=0.0.0.0
HOMEDRIVE_SERVER_CORS_ORIGIN=*

# ========== 存储配置 ==========
# 文件存储根目录
HOMEDRIVE_STORAGE_VOLUME=./HomeDrive

# ========== JWT 配置 ==========
# JWT 密钥（可选，未设置时自动生成）
HOMEDRIVE_JWT_SECRET=
# JWT 过期时间（小时）
HOMEDRIVE_JWT_EXPIRY_HOURS=168

# ========== 数据库配置 ==========
# 数据库 URL（SQLite 示例）
# 格式: sqlite:路径?mode=rwc
HOMEDRIVE_DATABASE_URL=sqlite:homedrive.db?mode=rwc
