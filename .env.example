# HomeDrive 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# ========== 服务配置 ==========
# 服务器端口
HOMEDRIVE_PORT=2300

# ========== 存储配置 ==========
# 文件存储根目录
HOMEDRIVE_VOLUME=./HomeDrive

# ========== JWT 配置 ==========
# JWT 密钥（可选，未设置时自动生成）
HOMEDRIVE_JWT_SECRET=

# ========== 数据库配置 ==========
# 数据库 URL（SQLite 示例）
# 格式: sqlite:路径?mode=rwc
HOMEDRIVE_DATABASE_URL=sqlite:homedrive.db?mode=rwc
